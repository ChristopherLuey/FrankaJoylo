<mujoco model="franka_panda">
  <compiler angle="radian" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.002"/>

  <default>
    <joint damping="10" armature="0.1"/>
    <geom type="capsule" rgba="0.9 0.9 0.9 1" contype="0" conaffinity="0"/>
    <position kp="200"/>
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" width="512" height="512"
             rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="1 1 3" dir="-0.3 -0.3 -1" diffuse="0.5 0.5 0.5"/>
    <geom type="plane" size="2 2 0.01" material="grid"/>

    <!-- Base -->
    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.08 0.025" pos="0 0 0.025" rgba="1 1 1 1"/>

      <!-- Link 1: base rotation -->
      <body name="link1" pos="0 0 0.333">
        <joint name="j1" axis="0 0 1" range="-2.8973 2.8973"/>
        <geom fromto="0 0 0 0 0 -0.28" size="0.06" rgba="1 1 1 1"/>

        <!-- Link 2: shoulder pitch -->
        <body name="link2" pos="0 0 0">
          <joint name="j2" axis="0 1 0" range="-1.7628 1.7628"/>
          <geom fromto="0 0 0 0 0 0.31" size="0.06" rgba="1 1 1 1"/>

          <!-- Link 3: upper arm rotation -->
          <body name="link3" pos="0 0 0.316">
            <joint name="j3" axis="0 0 1" range="-2.8973 2.8973"/>
            <geom fromto="0 0 0 0.08 0 0" size="0.05" rgba="0.9 0.9 0.9 1"/>

            <!-- Link 4: elbow -->
            <body name="link4" pos="0.0825 0 0">
              <joint name="j4" axis="0 -1 0" range="-3.0718 -0.0698"/>
              <geom fromto="0 0 0 -0.08 0 0.38" size="0.05" rgba="0.9 0.9 0.9 1"/>

              <!-- Link 5: forearm rotation -->
              <body name="link5" pos="-0.0825 0 0.384">
                <joint name="j5" axis="0 0 1" range="-2.8973 2.8973"/>
                <geom type="sphere" size="0.045" rgba="0.85 0.85 0.85 1"/>

                <!-- Link 6: wrist pitch -->
                <body name="link6" pos="0 0 0">
                  <joint name="j6" axis="0 1 0" range="-0.0175 3.7525"/>
                  <geom fromto="0 0 0 0.088 0 0" size="0.035" rgba="0.85 0.85 0.85 1"/>

                  <!-- Link 7: wrist roll -->
                  <body name="link7" pos="0.088 0 0">
                    <joint name="j7" axis="0 0 1" range="-2.8973 2.8973"/>
                    <geom type="cylinder" size="0.045 0.02" rgba="0.4 0.4 0.4 1"/>

                    <!-- End effector -->
                    <body name="ee" pos="0 0 0.107">
                      <geom type="sphere" size="0.025" rgba="0.8 0.15 0.15 1" contype="0" conaffinity="0"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="a1" joint="j1"/>
    <position name="a2" joint="j2"/>
    <position name="a3" joint="j3"/>
    <position name="a4" joint="j4"/>
    <position name="a5" joint="j5"/>
    <position name="a6" joint="j6"/>
    <position name="a7" joint="j7"/>
  </actuator>

  <keyframe>
    <!-- Typical Franka home pose -->
    <key name="home" qpos="0 -0.7854 0 -2.3562 0 1.5708 0.7854"/>
  </keyframe>
</mujoco>
